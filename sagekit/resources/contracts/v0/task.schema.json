{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sage-kit/task-dispatch/task.schema.json",
  "title": "SAGE-Kit Task Dispatch Task Record",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "priority",
    "status",
    "scope",
    "verification",
    "dependencies",
    "resources",
    "runs",
    "closure"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^TASK-[A-Za-z0-9._-]+$"
    },
    "type": {
      "type": "string",
      "enum": ["bug", "spec", "chore", "review", "integration", "release"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3"]
    },
    "status": {
      "type": "string",
      "enum": [
        "NEW",
        "TRIAGED",
        "READY",
        "IN_PROGRESS",
        "READY_FOR_REVIEW",
        "VERIFIED",
        "PARTIAL",
        "BLOCKED",
        "CLOSED"
      ]
    },
    "mode": {
      "type": "string"
    },
    "area": {
      "type": "array",
      "items": { "type": "string" }
    },
    "owner": {
      "type": "string"
    },
    "lifecycle": {
      "type": "object"
    },
    "scope": {
      "type": "object",
      "required": [
        "objective",
        "allowed_files",
        "read_only_files",
        "forbidden_files",
        "non_goals",
        "stop_conditions"
      ]
    },
    "verification": {
      "type": "object",
      "required": ["required_levels", "evidence_file", "mock_allowed"],
      "properties": {
        "required_levels": {
          "type": "array",
          "items": { "enum": ["L0", "L1", "L2", "L3", "L4"] }
        },
        "evidence_file": {
          "type": "string"
        },
        "mock_allowed": {
          "type": "boolean"
        }
      }
    },
    "dependencies": {
      "type": "object",
      "required": ["requires", "blocks"]
    },
    "resources": {
      "type": "object",
      "required": ["locks"]
    },
    "runs": {
      "type": "array"
    },
    "closure": {
      "type": "object"
    }
  }
}
